---
import Base from "../layouts/Base.astro";
import Seal from "../components/Seal.astro";
import tracks from "../data/tracks.json";
import crew from "../data/crew.json";
const SOUNDCLICK = "https://soundclick.com/dyea";
const codex = [
  { k: "PREMISE", q: "Funk is a substance.", p: "Bottled, weaponized, scarce in the dead zones. D'YEA and crew hunt it across the galaxy." },
  { k: "THE VESSEL", q: "I get my funk from a jar.", p: "The Bassstar — a lowrider that is also a spaceship. The crew's hero object, logo, and engine." },
  { k: "THE KOAN", q: "Life is a phase in phases.", p: "The cosmic philosophy under the party. You don't have to solve the riddle — D'YEA sings on." }
];
---
<Base>
  <header class="nav">
    <div class="wrap nav-in">
      <a class="brand" href="#top">D'<b>YEA</b></a>
      <nav class="nav-links" aria-label="Primary">
        <a href="#crew">Crew</a>
        <a href="#codex">Codex</a>
        <a href="#missions">Mission Files</a>
        <a href="#armory">Armory</a>
      </nav>
      <a class="nav-lic" href="/sync">Sync / License</a>
    </div>
  </header>

  <main id="top">
    <!-- HERO -->
    <section class="hero">
      <div class="wrap">
        <Seal />
        <p class="eyebrow">Signal re-acquired · Tampa Sector · 2003</p>
        <h1>D'<span class="ac">YEA</span></h1>
        <p class="tagline">Intergalactic funk-rock bounty hunters. The Bassstar Mission has been recovered.</p>
        <p class="sub">A 13-track transmission with a Rock &amp; Roll Hall of Fame drummer on the kit — cleared, remastered, and ready to hear.</p>
        <div class="cta-row">
          <a class="btn btn-gold" href={SOUNDCLICK} target="_blank" rel="noopener">▶ Listen now</a>
          <a class="btn btn-ghost" href="/sync">License this music</a>
        </div>
        <div class="hero-stat">
          <div><div class="n">13</div><div class="l">Transmissions</div></div>
          <div><div class="n">R&amp;RHOF</div><div class="l">On drums</div></div>
          <div><div class="n">2003</div><div class="l">Origin signal</div></div>
        </div>
      </div>
    </section>

    <!-- CREW -->
    <section class="section" id="crew">
      <div class="wrap reveal">
        <div class="section-head"><span class="tag">Crew Manifest</span><h2>The Crew</h2></div>
        <p class="lead">Four bounty hunters and one ancient anchor. Personas up front; the real names are on record below each.</p>
        <div class="crew">
          {crew.map((m) => (
            <article class={"member bracket" + (m.ancestor ? " ancestor" : "")}>
              <div class="pn">{m.ancestor ? "ANCESTOR" : "OPERATIVE"}</div>
              <div class="persona">{m.persona}</div>
              <div class="real">{m.real}</div>
              <div class="role">{m.role}</div>
              <div class="line">{m.line}</div>
              <div class="tagq">&ldquo;{m.tag}&rdquo;</div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- CODEX -->
    <section class="section" id="codex">
      <div class="wrap reveal">
        <div class="section-head"><span class="tag">The Bassstar Codex</span><h2>The Lore</h2></div>
        <div class="codex">
          {codex.map((b) => (
            <div class="beat bracket">
              <div class="k">{b.k}</div>
              <div class="q">{b.q}</div>
              <p>{b.p}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- MISSION FILES -->
    <section class="section" id="missions">
      <div class="wrap reveal">
        <div class="section-head"><span class="tag">Bassstar Mission</span><h2>Mission Files</h2></div>
        <p class="lead">Thirteen tracks, thirteen contracts. Encrypted files are lyrics still being decoded — the signal scattered.</p>
        <div class="missions">
          {tracks.map((t) => (
            <article class="mf">
              <div class="num">{String(t.n).padStart(2, "0")}</div>
              <div class="body">
                <div class="t">{t.title}{t.sub && <small>{t.sub}</small>}</div>
                <div class="threat">Threat level — {t.threat}</div>
                {t.anchor
                  ? <div class="anchor">&ldquo;{t.anchor}&rdquo;</div>
                  : <div class="anchor enc">[ Transmission encrypted — decode pending ]</div>}
                <div class="row">
                  <a class="play" href={SOUNDCLICK} target="_blank" rel="noopener" data-track={t.sub ? `${t.title} (${t.sub})` : t.title}>▶ Play</a>
                  {t.explicit && <span class="badge-x">Explicit</span>}
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- ARMORY + SYNC -->
    <section class="section" id="armory">
      <div class="wrap reveal">
        <div class="section-head"><span class="tag">Armory</span><h2>Gear &amp; Licensing</h2></div>
        <div class="armory">
          <div class="panel sync bracket">
            <h3>License this music</h3>
            <p>A pre-cleared funk-rock catalog built for picture — one owner, fast clearance, original compositions with authentic funk pedigree.</p>
            <div class="chips">
              <span class="chip">Funk-Rock</span><span class="chip">Swagger</span><span class="chip">Driving</span><span class="chip">Anthemic</span><span class="chip">Cosmic</span>
            </div>
            <a class="btn btn-gold" href="/sync">Open the sync portal</a>
          </div>
          <div class="panel bracket">
            <h3>Merch</h3>
            <p>Bassstar emblem patches, the funk jar, armored persona tees, and the physical Codex — staged behind the 2028 Silver Transmission.</p>
            <div class="soon">// Armory online soon — join the crew for first access</div>
          </div>
        </div>
      </div>
    </section>

    <!-- TRANSMISSION / EMAIL -->
    <section class="section transmission" id="join">
      <div class="wrap reveal">
        <div class="section-head" style="justify-content:center"><span class="tag">Transmission</span></div>
        <h2>Join the Crew</h2>
        <p class="lead" style="margin:10px auto 0">Decrypt the full Bassstar Codex, get the wallpaper pack, and be first when the signal goes live.</p>
        <form class="capture" name="join" method="POST" data-netlify="true" onsubmit="return false">
          <input type="email" name="email" placeholder="ENTER TRANSMISSION FREQUENCY (EMAIL)" aria-label="Email address" required />
          <button class="btn btn-gold" type="submit">Initiate</button>
        </form>
      </div>
    </section>
  </main>

  <footer>
    <div class="b">D'YEA</div>
    <p style="margin-top:8px">Bassstar Mission · © 2003–2026 D'YEA · Sonic Throne Publishing · Tampa Bay, FL</p>
    <p style="margin-top:6px"><a href="/sync">Sync &amp; licensing</a> · <a href={SOUNDCLICK} target="_blank" rel="noopener">SoundClick</a></p>
  </footer>

  <!-- persistent transmission console (signature element) -->
  <div class="console" role="region" aria-label="Transmission console">
    <div class="console-in">
      <a class="pp" href={SOUNDCLICK} target="_blank" rel="noopener" aria-label="Listen on SoundClick">▶</a>
      <div class="meta">
        <div class="lbl">Now transmitting</div>
        <div class="nowt" id="nowt">Bassstar Mission — full signal</div>
      </div>
      <div class="levels" aria-hidden="true"><span></span><span></span><span></span><span></span><span></span></div>
      <span class="clbl">Funk levels: max</span>
    </div>
  </div>

  <script is:inline>
    document.querySelectorAll('.play').forEach(el=>{
      el.addEventListener('click',()=>{const n=el.getAttribute('data-track');if(n){document.getElementById('nowt').textContent=n;}});
    });
  </script>
</Base>
