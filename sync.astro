---
import Base from "../layouts/Base.astro";
import tracks from "../data/tracks.json";
const CONTACT = "licensing@dyea.music"; // TODO: confirm public licensing address before launch
---
<Base title="D'YEA — Sync & Licensing" description="License D'YEA's funk-rock catalog for film, TV, advertising, games, and trailers. Clean edits, stems, cue sheets, fast turnaround.">
  <header class="nav">
    <div class="wrap nav-in">
      <a class="brand" href="/">D'<b>YEA</b></a>
      <nav class="nav-links" aria-label="Primary"><a href="/#missions">Catalog</a><a href="/#crew">Crew</a></nav>
      <a class="nav-lic" href="/">← Back to site</a>
    </div>
  </header>
  <main id="top">
    <section class="section" style="border-top:none;padding-top:64px">
      <div class="wrap">
        <div class="section-head"><span class="tag">For Supervisors &amp; Brands</span><h2>Sync &amp; Licensing</h2></div>
        <p class="lead">Music for film, TV, advertising, games, and trailers. High-energy funk-rock with authentic pedigree — Rock &amp; Roll Hall of Fame drummer on the record. One owner, fast clearance, no sample headaches. All public cues are clean; explicit versions available on request.</p>
        <div class="chips" style="margin-top:18px">
          <span class="chip">Funk-Rock</span><span class="chip">Rap-Rock</span><span class="chip">P-Funk Lineage</span><span class="chip">Energetic</span><span class="chip">Swagger</span><span class="chip">Retro-Future</span><span class="chip">Driving</span><span class="chip">Anthemic</span>
        </div>

        <div class="armory" style="margin-top:34px">
          <div class="panel sync bracket">
            <h3>Request the license pack</h3>
            <p>Clean edits + instrumental stems, BPM/key, mood tags, cue sheet, and one-sheet PDF. Target response: 48 hours.</p>
            <a class="btn btn-gold" href={`mailto:${CONTACT}?subject=D'YEA%20sync%20inquiry`}>Email licensing</a>
          </div>
          <div class="panel bracket">
            <h3>Catalog at a glance</h3>
            <p>13 original compositions, 2003. Self-released. Published by Sonic Throne Publishing.</p>
            <div class="soon">// Clean stems + rate card delivered on request</div>
          </div>
        </div>

        <div class="missions" style="margin-top:34px">
          {tracks.map((t) => (
            <article class="mf">
              <div class="num">{String(t.n).padStart(2,"0")}</div>
              <div class="body">
                <div class="t">{t.title}{t.sub && <small>{t.sub}</small>}</div>
                <div class="threat">{t.threat}</div>
                <div class="row">
                  <a class="play" href={`mailto:${CONTACT}?subject=${encodeURIComponent("Sync request: "+t.title)}`}>Request cue</a>
                  {t.explicit && <span class="badge-x">Explicit avail. on request</span>}
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  </main>
  <footer><div class="b">D'YEA</div><p style="margin-top:8px">Sync &amp; licensing · Sonic Throne Publishing · {CONTACT}</p></footer>
</Base>
