---
import "../styles/global.css";
import tracks from "../data/tracks.json";
const { title = "D'YEA — Bassstar Mission", description = "D'YEA: intergalactic funk-rock out of Tampa Bay. The 2003 album Bassstar Mission, with Rock & Roll Hall of Fame drummer Jerome 'Bigfoot' Brailey on the kit. Stream it. License it." } = Astro.props;
const site = Astro.site?.href?.replace(/\/$/, "") ?? "";

// JSON-LD: MusicAlbum + tracks (SEO / rich results)
const albumLD = {
  "@context": "https://schema.org",
  "@type": "MusicAlbum",
  "name": "Bassstar Mission",
  "byArtist": { "@type": "MusicGroup", "name": "D'YEA", "genre": ["Funk rock", "Rap rock"], "foundingLocation": "Tampa, Florida" },
  "datePublished": "2003",
  "numTracks": tracks.length,
  "track": tracks.map(t => ({
    "@type": "MusicRecording",
    "name": t.sub ? `${t.title} (${t.sub})` : t.title,
    "position": t.n
  }))
};
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="music.album" />
  {site && <link rel="canonical" href={site + Astro.url.pathname} />}
  <meta name="theme-color" content="#08070D" />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Anton&family=Chakra+Petch:wght@500;700&family=Space+Grotesk:wght@400;500;700&display=swap" rel="stylesheet" />
  <script type="application/ld+json" set:html={JSON.stringify(albumLD)} />
</head>
<body>
  <div class="fx fx-grid" aria-hidden="true"></div>
  <div class="fx fx-scan" aria-hidden="true"></div>
  <div class="fx-glow violet" aria-hidden="true"></div>
  <div class="fx-glow magenta" aria-hidden="true"></div>
  <slot />
  <script is:inline>
    const io = new IntersectionObserver((es)=>{es.forEach(e=>{if(e.isIntersecting){e.target.classList.add('in');io.unobserve(e.target);}})},{threshold:.12});
    document.querySelectorAll('.reveal').forEach(el=>io.observe(el));
  </script>
</body>
</html>
